rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'rivatagaston@gmail.com');
      allow create: if request.auth != null && request.auth.uid == userId && 
        ((request.auth.token.email == 'rivatagaston@gmail.com' && request.resource.data.role == "admin") || 
        (request.auth.token.email != 'rivatagaston@gmail.com' && request.resource.data.role == "operator"));
      allow update: if request.auth != null && request.auth.token.email == 'rivatagaston@gmail.com';
    }
  }
}
